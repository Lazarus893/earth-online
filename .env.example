# ─── OpenClaw Gateway (AI Agent Backend) ───
# The OpenClaw gateway provides AI agent capabilities (chat, planning, web search)
# Run your own OpenClaw instance or use a compatible OpenAI-format API
VITE_OPENCLAW_GATEWAY_URL=/api/openclaw
VITE_OPENCLAW_API_KEY=your_openclaw_api_key_here
VITE_OPENCLAW_MODEL=openclaw/codex

# ─── GLM (ZhipuAI) API ───
# Used for fallback AI chat when OpenClaw is unavailable
# Get your key at: https://open.bigmodel.cn/
VITE_GLM_API_KEY=your_glm_api_key_here
VITE_GLM_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions
VITE_GLM_MODEL=glm-4-flash

# ─── Supabase (Optional: Cloud Sync) ───
# Enables cross-device game state synchronization
# Create a project at: https://supabase.com/
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
